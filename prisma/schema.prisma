generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  password      String?                 // null for OAuth-only users
  scansBalance  Int       @default(50)  // free tier: 50 scans/month
  scansResetAt  DateTime?               // when balance resets next

  accounts       Account[]
  sessions       Session[]
  subscription   Subscription?
  savedAds       SavedAd[]
  savedSearches  SavedSearch[]
  scanPurchases  ScanPurchase[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Models ────────────────────────────────────────────────

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  plan             String    @default("free") // free | starter | premium | business
  lsCustomerId     String?   // LemonSqueezy customer ID
  lsOrderId        String?   // LemonSqueezy order ID
  lsSubscriptionId String?   // LemonSqueezy subscription ID
  lsVariantId      String?   // LemonSqueezy variant ID (maps to plan)
  status           String?   // active | cancelled | expired | paused
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Shop (aggregated from Ads by pageId) ─────────────────────
model Shop {
  id              String    @id @default(cuid())
  pageId          String    @unique
  pageName        String
  profilePicture  String?
  website         String?
  platforms       String[]
  countries       String[]

  totalAds        Int       @default(0)
  activeAds       Int       @default(0)
  pausedAds       Int       @default(0)

  firstSeenAt     DateTime  @default(now())
  lastAdSeenAt    DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([pageName])
  @@index([activeAds(sort: Desc)])
  @@index([lastAdSeenAt])
}

// Ads scraped from Facebook Ads Library
model Ad {
  id            String   @id @default(cuid())
  adArchiveId   String   @unique
  pageId        String?
  pageName      String?
  bodyText      String?
  title         String?
  description   String?
  imageUrl      String?
  videoUrl      String?
  adLibraryUrl  String?
  ctaType       String?
  platforms     String[]
  country       String   @default("US")
  isActive      Boolean  @default(true)
  startDate     DateTime?
  endDate       DateTime?
  pausedAt      DateTime?
  lastCheckedAt DateTime?
  checkCount    Int      @default(0)
  niche         String?
  rawData       Json
  scrapedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([country, isActive])
  @@index([pageName])
  @@index([scrapedAt])
  @@index([niche])
  @@index([isActive, lastCheckedAt])
  @@index([pageId])
}

model SavedAd {
  id        String   @id @default(cuid())
  userId    String
  adId      String
  adData    Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, adId])
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String               // tên hiển thị, VD: "Dropship fashion ads"
  filters   Json                 // lưu toàn bộ bộ lọc: {q, pageName, bodyText, niche, regex, ...}
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ScanPurchase {
  id          String   @id @default(cuid())
  userId      String
  scans       Int                   // number of scans purchased
  amountCents Int                   // price paid in cents
  lsOrderId   String?               // LemonSqueezy order ID
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}
