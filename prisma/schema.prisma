generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ───────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  password      String?                 // null for OAuth-only users
  scansBalance  Int       @default(50)  // free tier: 50 scans/month
  scansResetAt  DateTime?               // when balance resets next

  accounts       Account[]
  sessions       Session[]
  subscription   Subscription?
  savedAds       SavedAd[]
  savedShops     SavedShop[]
  savedSearches  SavedSearch[]
  scanPurchases  ScanPurchase[]
  tickets        Ticket[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── App Models ────────────────────────────────────────────────

model Subscription {
  id               String    @id @default(cuid())
  userId           String    @unique
  plan             String    @default("free") // free | starter | premium | business
  lsCustomerId     String?   // LemonSqueezy customer ID
  lsOrderId        String?   // LemonSqueezy order ID
  lsSubscriptionId String?   // LemonSqueezy subscription ID
  lsVariantId      String?   // LemonSqueezy variant ID (maps to plan)
  status           String?   // active | cancelled | expired | paused
  currentPeriodEnd DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Shop (aggregated from Ads by pageId) ─────────────────────
model Shop {
  id              String    @id @default(cuid())
  pageId          String    @unique
  pageName        String
  profilePicture  String?
  website         String?
  platforms       String[]
  countries       String[]

  totalAds        Int       @default(0)
  activeAds       Int       @default(0)
  pausedAds       Int       @default(0)

  firstSeenAt     DateTime  @default(now())
  lastAdSeenAt    DateTime?
  updatedAt       DateTime  @updatedAt

  @@index([pageName])
  @@index([activeAds(sort: Desc)])
  @@index([lastAdSeenAt])
}

// Ads scraped from Facebook Ads Library
model Ad {
  id            String   @id @default(cuid())
  adArchiveId   String   @unique
  pageId        String?
  pageName      String?
  bodyText      String?
  title         String?
  description   String?
  imageUrl      String?
  videoUrl      String?
  adLibraryUrl  String?
  ctaType       String?
  platforms     String[]
  country       String   @default("US")
  isActive      Boolean  @default(true)
  startDate     DateTime?
  endDate       DateTime?
  pausedAt      DateTime?
  lastCheckedAt DateTime?
  checkCount    Int      @default(0)
  niche         String?
  rawData       Json
  reach           Int?
  spend           String?       // range text like "100 - 500"
  impressions     String?       // range text
  website         String?       // landing page URL
  totalActiveTime Int?          // seconds
  dropshippingScore Int?
  scrapedAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([country, isActive])
  @@index([pageName])
  @@index([scrapedAt])
  @@index([niche])
  @@index([isActive, lastCheckedAt])
  @@index([pageId])
}

model SavedAd {
  id        String   @id @default(cuid())
  userId    String
  adId      String
  adData    Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, adId])
}

model ShopSnapshot {
  id        String   @id @default(cuid())
  pageId    String
  date      DateTime @db.Date
  activeAds Int      @default(0)
  totalAds  Int      @default(0)

  @@unique([pageId, date])
  @@index([pageId])
}

model SavedShop {
  id         String   @id @default(cuid())
  userId     String
  shopPageId String
  createdAt  DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, shopPageId])
  @@index([userId])
}

model SavedSearch {
  id        String   @id @default(cuid())
  userId    String
  name      String               // tên hiển thị, VD: "Dropship fashion ads"
  filters   Json                 // lưu toàn bộ bộ lọc: {q, pageName, bodyText, niche, regex, ...}
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ScanPurchase {
  id          String   @id @default(cuid())
  userId      String
  scans       Int                   // number of scans purchased
  amountCents Int                   // price paid in cents
  lsOrderId   String?               // LemonSqueezy order ID
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── Support Tickets ───────────────────────────────────────────
model Ticket {
  id        String   @id @default(cuid())
  userId    String
  subject   String
  body      String
  status    String   @default("open")   // open | in_progress | resolved | closed
  priority  String   @default("normal") // low | normal | high | urgent
  reply     String?
  repliedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
}

// ─── Announcements (admin-set banner) ─────────────────────────
model Announcement {
  id        String   @id @default(cuid())
  message   String
  color     String   @default("purple") // purple | blue | red | green | yellow
  isActive  Boolean  @default(true)
  link      String?                     // optional CTA link
  linkText  String?                     // optional CTA label
  createdAt DateTime @default(now())
  expiresAt DateTime?

  @@index([isActive])
}

// ─── AI Analysis Cache ─────────────────────────────────────────
model AiAnalysis {
  id         String   @id @default(cuid())
  targetType String                   // "ad" | "shop"
  targetId   String                   // adArchiveId or pageId
  model      String   @default("claude-sonnet-4-6")
  analysis   Json                     // structured result
  createdAt  DateTime @default(now())
  expiresAt  DateTime                 // 7-day TTL

  @@unique([targetType, targetId])
  @@index([expiresAt])
}

// ─── Workflow Run Log (Daily A scraper) ───────────────────────
model WorkflowRun {
  id         String   @id @default(cuid())
  runAt      DateTime @default(now())
  schedule   String?                  // "02:00" | "10:00" | "18:00" | "manual"
  status     String   @default("success") // success | error | partial
  totalAds   Int      @default(0)
  newAds     Int      @default(0)
  updatedAds Int      @default(0)
  errors     Int      @default(0)
  durationMs Int?
  notes      String?

  @@index([runAt(sort: Desc)])
  @@index([status])
}
